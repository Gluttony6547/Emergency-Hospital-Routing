# Dependencies
node_modules/

# Vite / local dev cache
.vite/
.cache/

# Build output, if any
dist/
build/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment / secrets
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/

# Temporary files
*.tmp
*.temp
*.bak
*.swp

# Local patch files
*.diff
*.patch

# Local archives
*.zip
*.rar
*.7z

# Python cache, if accidentally generated
__pycache__/
*.pyc